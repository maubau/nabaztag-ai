# Copy to .env (gitignored). Keys live here and nowhere else.
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=

# --- OJN / rabbit (names match what the code reads) ---
# Apache wrapper on the Bolt, port 80. NEVER :8080 (OJN's internal binary
# framing, not HTTP — docs/OJN_API_NOTES.md §1).
OJN_BASE_URL=http://127.0.0.1
# Rabbit's Wi-Fi MAC (colons) — used by deploy.sh for the DHCP static lease.
RABBIT_MAC=
# Rabbit's serial = the MAC without colons — used by the brain/MCP as VAPI sn.
RABBIT_SERIAL=
# VAPI token: /ojn_api/bunny/<sn>/getVAPIToken
OJN_VAPI_TOKEN=
# ojn-plugin-events webhook listener port (must match events/setWebhook)
NABAZTAG_EVENTS_PORT=8091

# --- Legacy AP (deploy.sh ap) ---
# Wi-Fi interface dedicated to the rabbit AP (UDOO Bolt AC 3168: wlp3s0)
AP_IFACE=wlp3s0
# Passphrase for the legacy WPA-TKIP AP (ojn/network/hostapd.conf, see §4.1)
# Use 8-63 characters from: letters, digits, dot, underscore, hyphen.
LEGACY_AP_PASSPHRASE=
