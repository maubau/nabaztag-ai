# Copy to .env (gitignored). Keys live here and nowhere else; never logged.
# --- LLM / STT / TTS keys ---
# OPENAI_API_KEY drives the agent (LLM, §6.2.5) and the Whisper STT fallback.
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
# ANTHROPIC_API_KEY is NOT required in this phase (OpenAI is the active LLM).
# ANTHROPIC_API_KEY=

# --- OJN / rabbit (names match what the code reads) ---
# Apache wrapper on the Bolt, port 80. NEVER :8080 (OJN's internal binary
# framing, not HTTP — docs/OJN_API_NOTES.md §1).
OJN_BASE_URL=http://127.0.0.1
# Rabbit's Wi-Fi MAC (colons) — used by deploy.sh for the DHCP static lease.
RABBIT_MAC=
# Rabbit's serial = the MAC without colons — used by the brain/MCP as VAPI sn.
RABBIT_SERIAL=
# VAPI token: /ojn_api/bunny/<sn>/getVAPIToken
OJN_VAPI_TOKEN=
# ojn-plugin-events webhook listener port (must match events/setWebhook)
NABAZTAG_EVENTS_PORT=8091

# --- TTS / audio out (Phase 2) ---
# deepgram | elevenlabs | piper. Unset = no local TTS (OJN tts/say is dead).
# PRODUCTION = piper since the July 2026 on-Nabaztag A/B (fixed Aura's low
# volume; both voices preferred). Deepgram remains the automatic fallback.
TTS_PROFILE=piper
# Deepgram TTS (/v1/speak) — voice routed by the STT-detected language:
# DEEPGRAM_TTS_VOICE_IT=aura-2-livia-it
# DEEPGRAM_TTS_VOICE_EN=aura-2-thalia-en
# Aura has no volume/gain request param; a non-zero value here is applied as
# a post-processing pass through ffmpeg (needs ffmpeg on PATH), chained with
# a peak limiter so it can't clip. Aura stayed quiet at +3dB; with Piper now
# production this mainly paces the FALLBACK, which inherits this value so a
# fallback utterance isn't suddenly quieter than Piper. +6dB recommended.
# DEEPGRAM_TTS_GAIN_DB=6
# ElevenLabs alternative:
ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL=eleven_multilingual_v2
# Piper (TTS_PROFILE=piper): HTTP client of a PERSISTENT local Piper service
# (the CLI reloads the model every call — too slow). One warm server per
# language, routed by the STT-detected language; both required. Piper is
# GPL-3.0 (OHF-Voice/piper1-gpl 1.4.2) and runs ONLY as an external localhost
# process — no Piper code is vendored into this Apache-2.0 tree. Voices selected
# on-Nabaztag (July 2026): IT it_IT-paola-medium (CC0 dataset); EN
# en_GB-alba-medium (Sam was judged flat). Alba's model is CC BY 4.0 →
# ATTRIBUTION REQUIRED: "en_GB-alba-medium" Piper voice, Alba dataset
# (University of Edinburgh), model card https://huggingface.co/rhasspy/piper-voices
# (en/en_GB/alba). Needs ffmpeg (WAV→MP3). Set up by ojn/piper/install-piper.sh.
# PIPER_URL_IT=http://127.0.0.1:5001
# PIPER_URL_EN=http://127.0.0.1:5002
# Per-language speaking pace (>1 slower, <1 faster; positive float). The raw
# voices run too fast in Italian; the tuned values are IT=1.25, EN=1.0.
# PIPER_LENGTH_SCALE_IT=1.25
# PIPER_LENGTH_SCALE_EN=1.0
# Runtime: Piper falls back to Deepgram on timeout/error (inherits
# DEEPGRAM_TTS_GAIN_DB). Set 0 to disable — the tts-bench forces this off so a
# Piper failure never counts as a silent Deepgram result.
# PIPER_FALLBACK_DEEPGRAM=1
# MP3 storage + delivery. The MTL decoder does NOT play audio served by the
# aiohttp server (hardware finding) — deliver via the Apache alias
# (ojn/apache/brain-audio.conf.example) and keep the brain storage-only:
NABAZTAG_AUDIO_DIR=www/audio
NABAZTAG_MP3_PORT=8090
NABAZTAG_MP3_SERVE_HTTP=0
NABAZTAG_MP3_BASE_URL=http://192.168.66.1/brain-audio

# --- Legacy AP (deploy.sh ap) ---
# Wi-Fi interface dedicated to the rabbit AP (UDOO Bolt AC 3168: wlp3s0)
AP_IFACE=wlp3s0
# Passphrase for the legacy WPA-TKIP AP (ojn/network/hostapd.conf, see §4.1)
# Use 8-63 characters from: letters, digits, dot, underscore, hyphen.
LEGACY_AP_PASSPHRASE=
