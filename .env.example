# Copy to .env (gitignored). Keys live here and nowhere else; never logged.
# --- LLM / STT / TTS keys ---
# OPENAI_API_KEY drives the agent (LLM, §6.2.5) and the Whisper STT fallback.
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
# ANTHROPIC_API_KEY is NOT required in this phase (OpenAI is the active LLM).
# ANTHROPIC_API_KEY=

# --- OJN / rabbit (names match what the code reads) ---
# Apache wrapper on the Bolt, port 80. NEVER :8080 (OJN's internal binary
# framing, not HTTP — docs/OJN_API_NOTES.md §1).
OJN_BASE_URL=http://127.0.0.1
# Rabbit's Wi-Fi MAC (colons) — used by deploy.sh for the DHCP static lease.
RABBIT_MAC=
# Rabbit's serial = the MAC without colons — used by the brain/MCP as VAPI sn.
RABBIT_SERIAL=
# VAPI token: /ojn_api/bunny/<sn>/getVAPIToken
OJN_VAPI_TOKEN=
# ojn-plugin-events webhook listener port (must match events/setWebhook)
NABAZTAG_EVENTS_PORT=8091

# --- TTS / audio out (Phase 2) ---
# deepgram | elevenlabs | piper. Unset = no local TTS (OJN tts/say is dead).
TTS_PROFILE=deepgram
# Deepgram TTS (/v1/speak) — voice routed by the STT-detected language:
# DEEPGRAM_TTS_VOICE_IT=aura-2-livia-it
# DEEPGRAM_TTS_VOICE_EN=aura-2-thalia-en
# ElevenLabs alternative:
ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL=eleven_multilingual_v2
# PIPER_MODEL=/path/to/voice.onnx        # for TTS_PROFILE=piper (needs ffmpeg)
# MP3 storage + delivery. The MTL decoder does NOT play audio served by the
# aiohttp server (hardware finding) — deliver via the Apache alias
# (ojn/apache/brain-audio.conf.example) and keep the brain storage-only:
NABAZTAG_AUDIO_DIR=www/audio
NABAZTAG_MP3_PORT=8090
NABAZTAG_MP3_SERVE_HTTP=0
NABAZTAG_MP3_BASE_URL=http://192.168.66.1/brain-audio

# --- Legacy AP (deploy.sh ap) ---
# Wi-Fi interface dedicated to the rabbit AP (UDOO Bolt AC 3168: wlp3s0)
AP_IFACE=wlp3s0
# Passphrase for the legacy WPA-TKIP AP (ojn/network/hostapd.conf, see §4.1)
# Use 8-63 characters from: letters, digits, dot, underscore, hyphen.
LEGACY_AP_PASSPHRASE=
