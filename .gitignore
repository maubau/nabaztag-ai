# Secrets & personal data — never committed (see docs/ARCHITECTURE.md §11.3)
.env
config.yaml
intents.yaml
ojn/network/hostapd.conf
ojn/network/dnsmasq.conf

# Generated audio & model weights
www/audio/
*.mp3
# Weights stay out of git, but the PROVENANCE record must not: without it a
# .onnx in models/wake/ is an unidentifiable binary. Re-include just those.
models/*
!models/wake/
models/wake/*
!models/wake/*.provenance.md
*.bin
*.onnx
*.ct2

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.ruff_cache/
dist/
build/

