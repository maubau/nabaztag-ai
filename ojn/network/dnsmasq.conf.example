# DHCP + DNS for the legacy rabbit segment (docs/ARCHITECTURE.md §4.1).
# Copy to dnsmasq.conf (gitignored); deploy.sh injects the rabbit's MAC from .env.

interface=__AP_IFACE__
bind-interfaces

# Legacy segment: 192.168.66.0/24 — its own subnet, no route to the home LAN.
dhcp-range=192.168.66.50,192.168.66.150,12h

# Static lease for the rabbit: a stable IP simplifies everything downstream.
# __RABBIT_MAC__ is replaced by deploy.sh from .env (RABBIT_MAC).
dhcp-host=__RABBIT_MAC__,192.168.66.10,nabaztag

# --- OJN platform hostname (REQUIRED, S1 field finding) ---
# The MTL bootcode does not special-case an IPv4-literal XMPP server: it hands
# whatever string it gets to the DNS resolver. The daemon therefore announces
# "ojn.local" (openjabnab.ini) and dnsmasq resolves it to the Bolt:
address=/ojn.local/192.168.66.1

# Optional extra override if a stock bootcode ever asks for Violet's hostname:
#address=/r.wizz.cc/192.168.66.1
