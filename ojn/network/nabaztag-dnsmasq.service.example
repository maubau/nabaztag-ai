[Unit]
Description=Nabaztag legacy DHCP and DNS
Requires=nabaztag-ap-interface.service
After=nabaztag-ap-interface.service
Before=hostapd.service

[Service]
Type=simple
ExecStart=/usr/sbin/dnsmasq --keep-in-foreground --conf-file=/etc/dnsmasq.d/nabaztag-legacy.conf --pid-file=
Restart=on-failure
RestartSec=2

[Install]
WantedBy=multi-user.target
