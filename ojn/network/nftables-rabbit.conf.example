#!/usr/sbin/nft -f
# Isolation rules for the legacy rabbit segment (docs/ARCHITECTURE.md §4.1).
# The rabbit's Wi-Fi is 2006-grade crypto (WPA-TKIP) — treat the segment as
# untrusted and contain it: rabbit ⇄ Bolt only, no home LAN, no internet.
#
# __AP_IFACE__ is rendered by deploy.sh. Bolt legacy IP = 192.168.66.1.

table inet rabbit_isolation {
    chain forward {
        type filter hook forward priority 0; policy accept;

        # Nothing from the legacy segment may be forwarded anywhere:
        # no home LAN, no internet. (Traffic *to the Bolt itself* is INPUT,
        # not FORWARD, so this single rule is the whole containment story.)
        iifname "__AP_IFACE__" drop
        oifname "__AP_IFACE__" drop
    }

    chain input {
        type filter hook input priority 0; policy accept;

        iifname "__AP_IFACE__" jump rabbit_input
    }

    chain rabbit_input {
        # Replies to connections initiated by the Bolt (including Gate S0 ping)
        ct state established,related accept
        # DHCP + DNS from dnsmasq
        udp dport { 67, 53 } accept
        tcp dport 53 accept
        # OJN HTTP wrapper/API + Nabaztag:tag XMPP transport
        tcp dport { 80, 8080, 5222 } accept
        # MP3 HTTP server (config.example.yaml: mp3_server.port)
        tcp dport 8090 accept
        # Ping for Gate S0 verification
        icmp type echo-request accept
        # Everything else from the rabbit segment to the Bolt: no
        drop
    }
}
